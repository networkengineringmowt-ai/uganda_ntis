PORT=3001

# Supabase project
SUPABASE_URL=https://your-project-ref.supabase.co

# Service-role key — PRIVILEGED, server-side ONLY. Bypasses Row Level Security.
# Get it from: Supabase Dashboard → Settings → API → service_role secret
# Never commit the real value or expose it in frontend code.
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key

# New-style Supabase API keys (optional — only needed if migrating off legacy JWT keys)
SUPABASE_SECRET_KEY=replace-with-sb-secret-key
SUPABASE_PUBLISHABLE_KEY=replace-with-sb-publishable-key

# Public anon key — used only for parity checks; the React client has its own copy
SUPABASE_ANON_KEY=replace-with-anon-key

# CORS — origin(s) allowed to call this server (comma-separated)
CORS_ORIGIN=http://localhost:5173

# Claude API key for the Road Asset Bot LLM proxy (/api/bot/chat)
ANTHROPIC_API_KEY=sk-ant-...

# G: Drive data store (canonical write target)
DRIVE_DATA_DIR=G:/My Drive/MOWT/Uganda National Road Network Repository/captures
# Mirror writes to Supabase too? on|off (default off — Drive is the store)
SUPABASE_MIRROR=off
