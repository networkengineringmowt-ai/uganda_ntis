{
  "name": "uganda-bms",
  "private": true,
  "version": "1.0.0",
  "description": "Uganda National Bridge & Major Culvert Management System — UNRA",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "npm --prefix server run dev",
    "dev:full": "concurrently -n REACT,SERVER -c cyan,magenta \"npm run dev\" \"npm run server\"",
    "export-data": "python scripts/export_data_for_deployment.py",
    "build": "npm run export-data && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist -b gh-pages"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "exceljs": "^4.4.0",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "recharts": "^2.14.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.14",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "vite": "^6.0.5"
  }
}
